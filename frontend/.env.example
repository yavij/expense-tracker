# ============================================
# Expense Tracker - Frontend Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# API Configuration
# -----------------
# Empty value uses same-origin (relative paths via Vite proxy)
# For local development with separate backend:
#   VITE_API_URL=http://localhost:7001
VITE_API_URL=

# Google OAuth
# ------------
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Firebase Configuration (required for Phone OTP login)
# -----------------------------------------------------
# 1. Create a project at https://console.firebase.google.com
# 2. Enable Phone Authentication: Authentication > Sign-in method > Phone
# 3. Add a Web app: Project Settings > General > Your apps > Add app (Web)
# 4. Copy the config values below
# 5. Add localhost to authorized domains: Authentication > Settings > Authorized domains
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id-here

# Razorpay (optional - for premium features)
# -------------------------------------------
# Get test key from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=your-razorpay-test-key-here
