# Database Configuration

# H2 (Development - file-based database)
JDBC_URL=jdbc:h2:./expensetracker;MODE=MySQL

# MySQL (Production - uncomment and configure)
# JDBC_URL=jdbc:mysql://localhost:3306/expensetracker?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

DB_USER=sa
DB_PASSWORD=

# Server Configuration
PORT=7000

# Security
JWT_SECRET=your-secret-jwt-key-change-this-in-production

# OAuth/Social Login
GOOGLE_CLIENT_ID=your-google-client-id-here
