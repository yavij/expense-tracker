# ========================================
# Expense Tracker - Backend Configuration
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database Configuration
# ----------------------
# H2 (Development - file-based database, no MySQL needed)
JDBC_URL=jdbc:h2:./expensetracker;MODE=MySQL;DATABASE_TO_LOWER=TRUE;AUTO_SERVER=TRUE
DB_USER=sa
DB_PASSWORD=

# MySQL (Production - uncomment and configure)
# JDBC_URL=jdbc:mysql://localhost:3306/expensetracker?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_USER=expensetracker
# DB_PASSWORD=your-secure-password-here

# Server Configuration
# --------------------
# Use 7001 on macOS (7000 conflicts with AirPlay Receiver), 7000 on Linux/Docker
PORT=7001

# Security
# --------
# IMPORTANT: Change this to a random 32+ character string in production!
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!

# OAuth / Social Login
# --------------------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here

# Email Notifications (optional)
# ------------------------------
# Set EMAIL_ENABLED=true to activate email sending
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Razorpay Payment Gateway (optional)
# ------------------------------------
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Market Rates - Gold & Silver API Keys (optional)
# ------------------------------------------------
# Without these keys, the app shows fallback/cached rates.
# Get from: https://www.goldapi.io (100 free requests/month)
GOLD_API_KEY=your-goldapi-key-here
# Get from: https://metalpriceapi.com (100 free requests/month)
METAL_PRICE_API_KEY=your-metalprice-api-key-here
