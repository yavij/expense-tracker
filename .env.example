# ============================================
# Expense Tracker - Docker Compose Configuration
# ============================================
# Copy this file to .env before running docker-compose:
#   cp .env.example .env

# Application port (exposed on host)
APP_PORT=7000

# MySQL Configuration
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-this-root-password
DB_USER=expensetracker
DB_PASSWORD=change-this-db-password

# JWT Secret (min 32 characters, change in production!)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-characters

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here

# Email Notifications (optional)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Razorpay Payment Gateway (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
